[
  {
    "battery": {
      "format": "[{capacity}]",
      "states": {
        "half": 50,
        "warning": 30,
        "critical": 15
      },
    },
    "clock": {
      "format": "[{:%a %d %b %H:%M}]"
    },
    "exclusive": true,
    "hyprland/language": {
      "format": "{}",
      "format-en": "[E]",
      "format-ru": "[R]"
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "1": "[/]",
        "2": "[W]",
        "3": "[;]",
        "4": "[4]",
        "5": "[5]",
        "6": "[6]",
        "7": "[7]",
        "8": "[R]",
        "9": "[9]",
        "10":"[X]"
      }
    },
    "layer": "bottom",
    "modules-center": [
      "custom/music",
      "pulseaudio",
    ],
    "modules-left": [
      "hyprland/workspaces",
      "hyprland/submap"
    ],
    "modules-right": [
      "network",
      "hyprland/language",
      "battery",
      "clock"
    ],
    "hyprland/submap": {
      "format": "[{}]"
    },
    "custom/music": {
      "format": "[{}",
      "return-type": "json",
      "exec": "waybar-module-music -f '%artist% %icon% %title%⦚' -m -t 15 -a 15 --effect-speed 300"
    },
    "network": {
      "format-disconnected": "[D]",
      "format-ethernet": "[{bandwidtnvim mini aihUpBytes}⮁{bandwidthDownBytes}]",
      "format-wifi": "[{bandwidthUpBytes}⮁{bandwidthDownBytes}⦚{signalStrength}]",
      "interval": 1,
    },
    "position": "top",
    "pulseaudio": {
      "format": "{volume}%]",
      "format-bluetooth": "{volume}%B]",
      "format-muted": "M]",
      "tooltip": false
    }
  }
]

[
  {
    "battery": {
      "format": "[{capacity}D]",
      "format-charging": "[{capacity}C]",
    },
    "clock": {
      "format": "[{:%a %d %b %H:%M}]"
    },
    "cpu": {
      "format": " {icon0}{icon1}{icon2}{icon3}{icon4}{icon5}{icon6}{icon7} ",
      "format-icons": [
       "🁣", "🁤", "🁥", "🁦", "🁧", "🁨", "🁩", 
       "🁪", "🁫", "🁬", "🁭", "🁮", "🁯", "🁰", 
       "🁱", "🁲", "🁳", "🁴", "🁵", "🁶", "🁷", 
       "🁸", "🁹", "🁺", "🁻", "🁼", "🁽", "🁾", 
       "🁿", "🂀", "🂁", "🂂", "🂃", "🂄", "🂅", 
       "🂆", "🂇", "🂈", "🂉", "🂊", "🂋", "🂌", 
       "🂍", "🂎", "🂏", "🂐", "🂑", "🂒", "🂓", "🁢"
      ],
      "interval": 1 
    },
    "exclusive": true,
    "hyprland/language": {
      "format": "{}",
      "format-en": "[E]",
      "format-ru": "[R]"
    },
    "hyprland/workspaces": {
      "format": "{icon}",
      "format-icons": {
        "1": "[/]",
        "2": "[W]",
        "3": "[;]",
        "5": "[🃁]",
        "8": "[R]",
        "9": "[V]",
        "10":"[M]"
      }
    },
    "layer": "bottom",
    "memory": {
      "format": "[{used:0.1f}|{swapUsed:0.1f}]",
      "interval": 2
    },
    "modules-center": [
      "hyprland/submap"
    ],
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-right": [
      "custom/music",
      "pulseaudio",
      "network",
      "cpu",
      "memory",
      "hyprland/language",
      "battery",
      "clock"
    ],
    "custom/music": {
      "format": "[{}",
      "return-type": "json",
      "exec": "waybar-module-music -f '%artist% %icon% %title%' -m -t 10 -a 10 --effect-speed 300"
    },
    "network": {
      "format-disconnected": "[Dwn]",
      "format-ethernet": "[Eth]",
      "format-wifi": "[{signalStrength}]",
      "interval": 1
    },
    "position": "top",
    "pulseaudio": {
      "format": "{volume}%]",
      "format-bluetooth": "{volume}%B]",
      "format-muted": "M]",
      "tooltip": false
    }
  }
]
